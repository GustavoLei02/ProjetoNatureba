# Copie este arquivo para .env e preencha os valores reais

PORT=3000
NODE_ENV=development

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_string_aleatoria_minimo_64_chars

# ─── BANCO DE DADOS ────────────────────────────────────────────────────────────
# Desenvolvimento local (SQLite em arquivo):
TURSO_DATABASE_URL=file:americanfit.db
TURSO_AUTH_TOKEN=

# Produção (Turso cloud — crie em turso.tech):
# 1. Instale a CLI: npm i -g @turso/cli
# 2. turso auth login
# 3. turso db create americanfit
# 4. turso db show americanfit --url   → cole em TURSO_DATABASE_URL
# 5. turso db tokens create americanfit → cole em TURSO_AUTH_TOKEN
# TURSO_DATABASE_URL=libsql://americanfit-<usuario>.turso.io
# TURSO_AUTH_TOKEN=<token_gerado>

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Em produção: URL exata do seu domínio Vercel (sem barra final)
ALLOWED_ORIGIN=http://localhost:3000

# ─── COINZZ API ────────────────────────────────────────────────────────────────
COINZZ_TOKEN=
COINZZ_API_URL=https://app.coinzz.com.br/api
COINZZ_OFFER_1MES=
COINZZ_OFFER_3MESES=
COINZZ_OFFER_5MESES=
